# UAT Environment Configuration
# Copy this file to .env.uat and fill in the values
# This environment is used for User Acceptance Testing (UAT)

# -------------------------------------------------------
# Google OAuth2 Credentials (UAT-specific)
# Create a separate OAuth2 client in Google Cloud Console for UAT
# Add Authorized redirect URI: https://<uat-domain>/api/auth/callback
# -------------------------------------------------------
GOOGLE_CLIENT_ID=your-uat-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-uat-google-client-secret

# UAT application base URL
NEXTAUTH_URL=https://job-dashboard-uat.example.com

# Secret for signing session cookies (generate with: openssl rand -base64 32)
SESSION_SECRET=your-uat-session-secret-change-me

# -------------------------------------------------------
# Database (separate UAT Neon Postgres project/branch)
# Provision a dedicated UAT database to avoid polluting production data
# -------------------------------------------------------
DATABASE_URL=postgresql://user:password@uat-db-host/job_dashboard_uat

# -------------------------------------------------------
# UAT-specific flags
# -------------------------------------------------------
# Set to "true" to enable test-only API endpoints (seed/reset)
ENABLE_UAT_ENDPOINTS=true

# Node environment
NODE_ENV=test
